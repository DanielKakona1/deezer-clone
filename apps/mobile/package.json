{
  "name": "@deezer-mobile-clone/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --clear",
    "start": "pnpm dev",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint --ext .ts,.tsx src",
    "format": "prettier --check \"{src,app.json,babel.config.js,jest.config.js,jest.setup.ts}/**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --passWithNoTests src",
    "test:integration": "jest --passWithNoTests --testPathPattern='src/(app|tests/app)'",
    "test:e2e": "maestro test .maestro/search-artist-flow.yaml"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@expo-google-fonts/poppins": "^0.4.1",
    "@tanstack/react-query": "^5.90.5",
    "axios": "^1.12.2",
    "expo": "~54.0.33",
    "expo-font": "~14.0.9",
    "expo-image": "~3.0.10",
    "expo-router": "~6.0.14",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-screens": "4.16.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-reanimated": "~4.1.1",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@types/styled-components-react-native": "^5.2.5",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.11",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
